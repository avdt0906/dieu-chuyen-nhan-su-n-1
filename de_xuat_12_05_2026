    <span class="vitri-badge ${t.vitri}">${t.vitri}</span>
    ${t.hist?'<span class="history-badge">✓ Từng làm</span>':''}
    ${t.cung?'<span class="same-gdkv-badge" style="color:'+col+'">● Cùng GĐKV</span>':'<span class="cross-gdkv-badge">⇄ Khác GĐKV</span>'}
    <span class="score-num">⭐ ${t.score}</span>
  </div>
  <div class="salon-flow">
    <div class="salon-box">
      <div class="salon-num">${sName(t.sg)}</div>
      <div class="salon-gdkv" style="color:${gdkvColor(t.gg)}">${gg} · S${t.sg}</div>
      <div class="salon-stats"><span class="salon-stat">${t.nv_g} NV</span><span class="salon-stat">${t.kpn_g} KH/NV</span><span class="nhom-tag nhom-${t.ng}">${t.ng==='Lon'?'Lớn':t.ng}</span></div>
    </div>
    <div class="arrow-col">→</div>
    <div class="salon-box">
      <div class="salon-num">${sName(t.sn)}</div>
      <div class="salon-gdkv" style="color:${gdkvColor(t.gn)}">${gn} · S${t.sn}</div>
      <div class="salon-stats"><span class="salon-stat">${t.nv_n} NV</span><span class="salon-stat ${t.kpn_n>=10?'overload':''}">${t.kpn_n} KH/NV</span><span class="nhom-tag nhom-${t.nn}">${t.nn==='Lon'?'Lớn':t.nn}</span></div>
    </div>
  </div>
  <div class="card-footer">
    <span class="nv-info">NV #${t.nv_id}${t.aov_nv>0?' · AOV '+fmtNum(t.aov_nv)+'đ':''}</span>
    <span class="km-badge">📍 ${t.km} km</span>
    <span class="delta-dt">+${fmtDT(t.ddt)}</span>
  </div>
</div>`;}

function renderCB(cb){
  const col=gdkvColor(cb.gdkv),mx=45;
  return `<div class="b-card">
  <div class="b-card-header"><span class="alert-icon">🔴</span>
    <div><div class="b-salon-name">${sName(cb.salon)} — ${cb.vitri} <span style="font-size:13px;font-weight:400;color:var(--text-dim)">(S${cb.salon})</span></div>
    <div class="b-gdkv" style="color:${col}">${cg(cb.gdkv)} · Nhóm ${cb.nhom==='Lon'?'Lớn':cb.nhom}</div></div>
  </div>
  <div class="load-bar-wrap">
    <div class="load-label"><span>Hiện tại: ${cb.kpn_now} KH/NV (ngưỡng ${cb.nguong})</span><span>${cb.nv_lam} NV</span></div>
    <div class="load-bar"><div class="load-fill over" style="width:${Math.min(100,cb.kpn_now/mx*100)}%"></div></div>
    <div class="load-label" style="margin-top:6px"><span>Sau khi gọi: ${cb.kpn_after} KH/NV</span><span>${cb.nv_lam+1} NV</span></div>
    <div class="load-bar"><div class="load-fill after" style="width:${Math.min(100,cb.kpn_after/mx*100)}%"></div></div>
  </div>
  <div style="font-size:12px;color:var(--text-dim);margin-bottom:10px">${cb.nv_nghi} NV nghỉ có thể được gọi</div>
  <div class="b-metrics">
    <div class="b-metric"><div class="b-metric-val neu">${fmtNum(cb.inc_dt)}</div><div class="b-metric-lbl">Incremental DT</div></div>
    <div class="b-metric"><div class="b-metric-val pos">${cb.nv_lam+1} NV</div><div class="b-metric-lbl">Sau khi gọi thêm</div></div>
  </div>
</div>`;}

function renderTab(key){
  const d=DATES[key], ts=d.transfers;
  const totalDDT=ts.reduce((a,t)=>a+t.ddt,0);
  const gdkvSet=[...new Set([...ts.map(t=>cg(t.gg)),...ts.map(t=>cg(t.gn))])].sort();
  const byG={};ts.forEach(t=>{const g=cg(t.gg);if(!byG[g])byG[g]={count:0,ddt:0};byG[g].count++;byG[g].ddt+=t.ddt;});
  const gs=Object.entries(byG).sort((a,b)=>b[1].ddt-a[1].ddt);
  document.getElementById(key).innerHTML=`
<div class="summary-bar">
  <div class="stat-card highlight">
    <div class="stat-label">Tổng ΔDT Điều chuyển</div>
    <div class="stat-value">${fmtNum(Math.round(totalDDT/1000))}K</div>
    <div class="stat-sub">${ts.length} đề xuất · ${gdkvSet.length} GĐKV</div>
  </div>
  ${gs.slice(0,5).map(([g,v])=>`<div class="stat-card" style="border-left:3px solid ${gdkvColor(g)}"><div class="stat-label" style="color:${gdkvColor(g)}">${g}</div><div class="stat-value" style="font-size:20px">${fmtNum(Math.round(v.ddt/1000))}K</div><div class="stat-sub">${v.count} cặp</div></div>`).join('')}
</div>
<div class="filter-row" id="filter-${key}">
  <span class="filter-label">Lọc theo GĐKV:</span>
  <button class="chip chip-all active" onclick="filterCards('${key}','ALL')">Tất cả</button>
  ${gdkvSet.map(g=>`<button class="chip active" style="background:${gdkvColor(g)}22;color:${gdkvColor(g)};border-color:${gdkvColor(g)}88" onclick="filterCards('${key}','${g}')">${g}</button>`).join('')}
</div>
<div class="section-header"><div class="section-icon a">🔄</div><span class="section-title">Hướng 1 — Điều chuyển Nhân sự</span><span class="section-count">${ts.length} đề xuất</span></div>
<div class="cards-grid" id="cards-${key}">${ts.map(renderCard).join('')}</div>
${d.callbacks.length>0?`<div class="section-b-sep"><hr class="divider"><div class="section-header"><div class="section-icon b">🔴</div><span class="section-title">Hướng 2 — Gọi NV Nghỉ Đi Làm Thêm</span><span class="section-count">${d.callbacks.length} đề xuất</span></div><div class="b-cards">${d.callbacks.map(renderCB).join('')}</div></div>`:''}
`;}

function filterCards(key,gdkv){
  const chips=document.querySelectorAll('#filter-'+key+' .chip');
  chips.forEach(c=>c.classList.remove('active'));
  if(gdkv==='ALL'){
    document.querySelector('#filter-'+key+' .chip-all').classList.add('active');
    document.querySelectorAll('#cards-'+key+' .card').forEach(c=>c.removeAttribute('data-hidden'));
  } else {
    chips.forEach(c=>{if(c.textContent.trim()===gdkv)c.classList.add('active');});
    document.querySelectorAll('#cards-'+key+' .card').forEach(c=>{
      c.setAttribute('data-hidden',(c.getAttribute('data-gg')!==gdkv&&c.getAttribute('data-gn')!==gdkv)?'true':'false');
    });
  }
}

function switchTab(key){
  document.querySelectorAll('.tab-content').forEach(e=>e.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(e=>e.classList.remove('active'));
  document.getElementById(key).classList.add('active');
  document.querySelectorAll('.tab-btn')[0].classList.add('active');
}

renderTab('t0512');
</script>
</body>
</html>
